---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { readData } from '../lib/readData';
const sobreData = readData('sobre.json');
const siteConfig = readData('siteConfig.json');
---

<BaseLayout
  title={sobreData.seo?.title || "Sobre Nós"}
  description={sobreData.seo?.description}
  image={sobreData.seo?.image}
>

  <section class="max-w-6xl mx-auto px-4 py-10">
    <div class="mb-6">
      <h1 class="text-3xl font-bold" style="font-family: var(--font-heading);">{sobreData.seo?.title || "Sobre Nós"}</h1>
      <nav class="text-sm text-gray-500 mt-1">
        <a href="/" class="hover:text-gray-700">Home</a>
        <span class="mx-2">/</span>
        <span>Sobre</span>
      </nav>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <div class="flex-1 min-w-0">
        <div class="bg-white rounded-xl border border-gray-200 p-6">

          {sobreData.hero?.image && (
            <img src={sobreData.hero.image} alt={siteConfig.name} class="w-full h-64 object-cover rounded-lg mb-6" />
          )}

          {sobreData.hero?.desc && <p class="text-gray-700 mb-4">{sobreData.hero.desc}</p>}

          {sobreData.content?.missionTitle && (
            <>
              <h4 class="text-lg font-bold mt-6 mb-2" style="font-family: var(--font-heading);">{sobreData.content.missionTitle}</h4>
              <p class="text-gray-700">{sobreData.content.missionText}</p>
            </>
          )}

          {sobreData.content?.teamTitle && (
            <>
              <h4 class="text-lg font-bold mt-6 mb-2" style="font-family: var(--font-heading);">{sobreData.content.teamTitle}</h4>
              <p class="text-gray-700">{sobreData.content.teamText}</p>
            </>
          )}

          <hr class="my-6 border-gray-200" />

          <div class="flex gap-4">
            {siteConfig.social?.facebook && (
              <a href={siteConfig.social.facebook} target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-[--color-primary]">Facebook</a>
            )}
            {siteConfig.social?.twitter && (
              <a href={siteConfig.social.twitter} target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-[--color-primary]">Twitter</a>
            )}
            {siteConfig.social?.instagram && (
              <a href={siteConfig.social.instagram} target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-[--color-primary]">Instagram</a>
            )}
          </div>
        </div>
      </div>

      <aside class="lg:w-80 flex-shrink-0">
        <Sidebar />
      </aside>
    </div>
  </section>

</BaseLayout>
